model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["dim_date","dim_dealer","dim_model","fact_sales"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["MCP-PBIModeling","DevMode"]

ref table dim_date
ref table dim_dealer
ref table dim_model
ref table fact_sales
ref table 'Metric Parameter'
ref table 'Discount Change'

